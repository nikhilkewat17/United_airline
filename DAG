from datetime import datetime, timedelta
import csv
import io
import statistics

import boto3

from airflow import DAG
from airflow.operators.python import PythonOperator
from airflow.models import DagRun
from airflow.utils.session import create_session
from airflow.utils import timezone


LOOKBACK_DAYS = 14

S3_BUCKET = "dre-rms-mwaa-rms-stg"
S3_KEY_PREFIX = "dags2/reports"


def get_avg_runtime_minutes(dag_id):

    durations = []

    lookback_date = timezone.utcnow() - timedelta(days=LOOKBACK_DAYS)

    with create_session() as session:

        dag_runs = (
            session.query(DagRun)
            .filter(
                DagRun.dag_id == dag_id,
                DagRun.state == "success",
                DagRun.execution_date >= lookback_date
            )
            .all()
        )

        for dr in dag_runs:

            if dr.start_date and dr.end_date:

                runtime = (
                    dr.end_date - dr.start_date
                ).total_seconds() / 60

                print(
                    f"DAG={dag_id} | "
                    f"RUN_ID={dr.run_id} | "
                    f"START={dr.start_date} | "
                    f"END={dr.end_date} | "
                    f"RUNTIME_MINUTES={runtime}"
                )
                if runtime >= 30:
                    durations.append(runtime)
                else:
                    print(
                        f"IGNORING RUN {dr.run_id} "
                        f"BECAUSE RUNTIME={runtime}"
                    )

    if not durations:
        return None
    
    print(
        f"DAG={dag_id}, "
        f"VALID_RUNS={len(durations)}, "
        f"MEDIAN_RUNTIME={statistics.median(durations)}"
    )

    return round(statistics.median(durations), 2)


def get_remaining_runtime_minutes(dag_id, avg_runtime):

    with create_session() as session:

        running_dag = (
            session.query(DagRun)
            .filter(
                DagRun.dag_id == dag_id,
                DagRun.state == "running"
            )
            .order_by(DagRun.execution_date.desc())
            .first()
        )

        if not running_dag:
            return avg_runtime, 0
        
        print("========== RUNNING DAG ==========")
        print(f"DAG ID : {dag_id}")
        print(f"RUN ID : {running_dag.run_id}")
        print(f"STATE : {running_dag.state}")
        print(f"START DATE : {running_dag.start_date}")
        print(f"EXEC DATE : {running_dag.execution_date}")
        print("=================================")
        


        elapsed_minutes = (
            timezone.utcnow() - running_dag.start_date
        ).total_seconds() / 60

        remaining_minutes = max(
            avg_runtime - elapsed_minutes,
            0
        )

        return round(remaining_minutes, 2), round(elapsed_minutes, 2)


def upload_to_s3(csv_content):

    s3 = boto3.client("s3")

    file_name = (
        f"dag_eta_"
        f"{timezone.utcnow().strftime('%Y%m%d_%H%M%S')}.csv"
    )

    s3_key = f"{S3_KEY_PREFIX}/{file_name}"

    s3.put_object(
        Bucket=S3_BUCKET,
        Key=s3_key,
        Body=csv_content,
        ContentType="text/csv"
    )

    print(f"CSV uploaded to s3://{S3_BUCKET}/{s3_key}")


def calculate_eta(**context):

    dag_run = context.get("dag_run")

    if not dag_run:
        raise ValueError("dag_run not found")

    dag_sequence = dag_run.conf.get("dag_sequence")

    if not dag_sequence:
        raise ValueError(
            "dag_sequence is mandatory in dag_run.conf"
        )

    current_running_dag = dag_sequence[0]
    target_dag = dag_sequence[-1]

    print(f"DAG Sequence : {dag_sequence}")
    print(f"Current DAG : {current_running_dag}")
    print(f"Target DAG : {target_dag}")

    csv_buffer = io.StringIO()
    writer = csv.writer(csv_buffer)

    writer.writerow([
        "dag_id",
        "avg_runtime_minutes",
        "elapsed_minutes",
        "remaining_minutes"
    ])

    total_remaining_minutes = 0

    for dag_id in dag_sequence:

        avg_runtime = get_avg_runtime_minutes(dag_id)

        if avg_runtime is None:

            writer.writerow([
                dag_id,
                "NO_HISTORY",
                "",
                ""
            ])

            continue

        if dag_id == current_running_dag:

            remaining_runtime, elapsed_minutes = (
                get_remaining_runtime_minutes(
                    dag_id,
                    avg_runtime
                )
            )

            total_remaining_minutes += remaining_runtime

            writer.writerow([
                dag_id,
                avg_runtime,
                elapsed_minutes,
                remaining_runtime
            ])

        else:

            total_remaining_minutes += avg_runtime

            writer.writerow([
                dag_id,
                avg_runtime,
                "",
                avg_runtime
            ])

    current_time = timezone.utcnow()

    estimated_completion_time = (
        current_time +
        timedelta(minutes=total_remaining_minutes)
    )

    writer.writerow([])
    writer.writerow(["SUMMARY"])

    writer.writerow([
        "Current Running DAG",
        current_running_dag
    ])

    writer.writerow([
        "Target DAG",
        target_dag
    ])

    writer.writerow([
        "Total Remaining Minutes",
        round(total_remaining_minutes, 2)
    ])

    writer.writerow([
        "Current UTC Time",
        current_time.strftime("%Y-%m-%d %H:%M:%S")
    ])

    writer.writerow([
        "Estimated Completion Time",
        estimated_completion_time.strftime("%Y-%m-%d %H:%M:%S")
    ])

    upload_to_s3(csv_buffer.getvalue())


with DAG(
    dag_id="dre_dag_eta_calculator",
    start_date=datetime(2025, 1, 1),
    schedule=None,
    catchup=False,
    tags=["eta", "monitoring"]
) as dag:

    eta_task = PythonOperator(
        task_id="calculate_dag_eta",
        python_callable=calculate_eta
    )
