def get_remaining_task_hours(
    dag_id,
    task_id,
    avg_hours
):

    with create_session() as session:

        running_task = (
            session.query(TaskInstance)
            .filter(
                TaskInstance.dag_id == dag_id,
                TaskInstance.task_id == task_id,
                TaskInstance.state == State.RUNNING
            )
            .order_by(
                TaskInstance.start_date.desc()
            )
            .first()
        )

        if not running_task:
            return avg_hours, 0

        elapsed_hours = (
            timezone.utcnow()
            - running_task.start_date
        ).total_seconds() / 3600

        remaining_hours = max(
            avg_hours - elapsed_hours,
            0
        )

        return (
            round(remaining_hours, 2),
            round(elapsed_hours, 2)
        )


