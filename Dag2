from datetime import datetime, timedelta
import csv
import io
import statistics

import boto3

from airflow import DAG
from airflow.operators.python import PythonOperator
from airflow.models import TaskInstance
from airflow.utils.state import State
from airflow.utils.session import create_session
from airflow.utils import timezone


LOOKBACK_DAYS = 7

S3_BUCKET = "dre-rms-mwaa-rms-stg"
S3_KEY_PREFIX = "dags2/reports"

def get_task_runtime_hours(dag_id, task_id):

    durations = []

    lookback_date = timezone.utcnow() - timedelta(days=LOOKBACK_DAYS)

    with create_session() as session:

        task_instances = (
            session.query(TaskInstance)
            .filter(
                TaskInstance.dag_id == dag_id,
                TaskInstance.task_id == task_id,
                TaskInstance.state == State.SUCCESS,
                TaskInstance.execution_date >= lookback_date
            )
            .all()
        )

        for ti in task_instances:

            if ti.duration and ti.duration > 60:

                runtime_hours = ti.duration / 3600
                
                print(
                    f"DAG={dag_id} | "
                    f"TASK={task_id} | "
                    f"RUN_ID={ti.run_id} | "
                    f"DURATION_SECONDS={ti.duration}"

                )

                durations.append(runtime_hours)

        if not durations:
            return None

        return round(statistics.median(durations), 2)



def get_remaining_task_hours(
    dag_id,
    task_id,
    avg_hours
):

    with create_session() as session:

        running_task = (
            session.query(TaskInstance)
            .filter(
                TaskInstance.dag_id == dag_id,
                TaskInstance.task_id == task_id,
                TaskInstance.state == State.RUNNING
            )
            .order_by(
                TaskInstance.start_date.desc()
            )
            .first()
        )

        if not running_task:
            return avg_hours, 0

        elapsed_hours = (
            timezone.utcnow()
            - running_task.start_date
        ).total_seconds() / 3600

        remaining_hours = max(
            avg_hours - elapsed_hours,
            0
        )

        return (
            round(remaining_hours, 2),
            round(elapsed_hours, 2)
        )


def upload_to_s3(csv_content):

    s3 = boto3.client("s3")

    file_name = (
        f"dag_eta_"
        f"{timezone.utcnow().strftime('%Y%m%d_%H%M%S')}.csv"
    )

    s3_key = f"{S3_KEY_PREFIX}/{file_name}"

    s3.put_object(
        Bucket=S3_BUCKET,
        Key=s3_key,
        Body=csv_content,
        ContentType="text/csv"
    )

    print(f"CSV uploaded to s3://{S3_BUCKET}/{s3_key}")


def calculate_eta(**context):

    dag_run = context.get("dag_run")

    if not dag_run:
        raise ValueError("dag_run not found")

    task_sequence = dag_run.conf.get("task_sequence")

    if not task_sequence:
        raise ValueError(
            "dag_sequence is mandatory in dag_run.conf"
        )

    current_task = task_sequence[0]
    target_task = task_sequence[-1]

    print(f"DAG Sequence : {task_sequence}")
    print(f"Current DAG : {current_task}")
    print(f"Target DAG : {target_task}")

    csv_buffer = io.StringIO()
    writer = csv.writer(csv_buffer)

    writer.writerow([
        "dag_id",
        "task_id",
        "avg_runtime_hours",
        "elapsed_hours",
        "remaining_hours"
    ])

    total_remaining_hours = 0

    for index, item in enumerate(task_sequence):

        dag_id = item["dag_id"]
        task_id = item["task_id"]

        avg_hours = get_task_runtime_hours(
            dag_id,
            task_id
        )

        if avg_hours is None:

            writer.writerow([
               dag_id,
               task_id,
               "NO_HISTORY",
               "",
               ""
            ])
            continue

        if index == 0:
            remaining_hours, elapsed_hours = (
                get_remaining_task_hours(
                    dag_id,
                    task_id,
                    avg_hours
                )
            )
            total_remaining_hours += remaining_hours

            writer.writerow([
                dag_id,
                task_id,
                avg_hours,
                elapsed_hours,
                remaining_hours
                ])
        else:
            total_remaining_hours += avg_hours

            writer.writerow([
                dag_id,
                task_id,
                avg_hours,
                "",
                avg_hours
            ])


    current_time = timezone.utcnow()

    estimated_completion_time = (
        current_time +
        timedelta(hours=total_remaining_hours)
    )

    writer.writerow([])
    writer.writerow(["SUMMARY"])

    writer.writerow([
        "Current Running DAG",
        current_task["task_id"]
    ])

    writer.writerow([
        "Target DAG",
        target_task["task_id"]
    ])

    writer.writerow([
        "Total Remaining Hours",
        round(total_remaining_hours, 2)
    ])

    writer.writerow([
        "Current UTC Time",
        current_time.strftime("%Y-%m-%d %H:%M:%S")
    ])

    writer.writerow([
        "Estimated Completion Time",
        estimated_completion_time.strftime("%Y-%m-%d %H:%M:%S")
    ])

    upload_to_s3(csv_buffer.getvalue())


with DAG(
    dag_id="dre_task_eta_calculator",
    start_date=datetime(2025, 1, 1),
    schedule=None,
    catchup=False,
    tags=["eta", "monitoring"]
) as dag:

    eta_task = PythonOperator(
        task_id="calculate_task_eta",
        python_callable=calculate_eta
    )
