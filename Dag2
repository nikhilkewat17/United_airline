LOOKBACK_DAYS = 7

S3_BUCKET = "dre-rms-mwaa-rms-stg"
S3_KEY_PREFIX = "dags2/reports"




def upload_to_s3(csv_content):

    s3 = boto3.client("s3")

    file_name = (
        f"dag_eta_"
        f"{timezone.utcnow().strftime('%Y%m%d_%H%M%S')}.csv"
    )

    s3_key = f"{S3_KEY_PREFIX}/{file_name}"

    s3.put_object(
        Bucket=S3_BUCKET,
        Key=s3_key,
        Body=csv_content,
        ContentType="text/csv"
    )

    print(f"CSV uploaded to s3://{S3_BUCKET}/{s3_key}")


def calculate_eta(**context):

    dag_run = context.get("dag_run")

    if not dag_run:
        raise ValueError("dag_run not found")

    task_sequence = dag_run.conf.get("task_sequence")

    if not task_sequence:
        raise ValueError(
            "dag_sequence is mandatory in dag_run.conf"
        )

    current_running_dag = task_sequence[0]
    target_dag = task_sequence[-1]

    print(f"DAG Sequence : {task_sequence}")
    print(f"Current DAG : {current_running_dag}")
    print(f"Target DAG : {target_dag}")

    csv_buffer = io.StringIO()
    writer = csv.writer(csv_buffer)

    writer.writerow([
        "dag_id",
        "task_id",
        "avg_runtime_minutes",
        "elapsed_minutes",
        "remaining_minutes"
    ])

    total_remaining_minutes = 0

    for dag_id in dag_sequence:

        avg_runtime = get_avg_runtime_minutes(dag_id)

        if avg_runtime is None:

            writer.writerow([
                dag_id,
                "NO_HISTORY",
                "",
                ""
            ])

            continue

        if dag_id == current_running_dag:

            remaining_runtime, elapsed_minutes = (
                get_remaining_runtime_minutes(
                    dag_id,
                    avg_runtime
                )
            )

            total_remaining_minutes += remaining_runtime

            writer.writerow([
                dag_id,
                avg_runtime,
                elapsed_minutes,
                remaining_runtime
            ])

        else:

            total_remaining_minutes += avg_runtime

            writer.writerow([
                dag_id,
                avg_runtime,
                "",
                avg_runtime
            ])

    current_time = timezone.utcnow()

    estimated_completion_time = (
        current_time +
        timedelta(minutes=total_remaining_minutes)
    )

    writer.writerow([])
    writer.writerow(["SUMMARY"])

    writer.writerow([
        "Current Running DAG",
        current_running_dag
    ])

    writer.writerow([
        "Target DAG",
        target_dag
    ])

    writer.writerow([
        "Total Remaining Minutes",
        round(total_remaining_minutes, 2)
    ])

    writer.writerow([
        "Current UTC Time",
        current_time.strftime("%Y-%m-%d %H:%M:%S")
    ])

    writer.writerow([
        "Estimated Completion Time",
        estimated_completion_time.strftime("%Y-%m-%d %H:%M:%S")
    ])

    upload_to_s3(csv_buffer.getvalue())


with DAG(
    dag_id="dre_task_eta_calculator",
    start_date=datetime(2025, 1, 1),
    schedule=None,
    catchup=False,
    tags=["eta", "monitoring"]
) as dag:

    eta_task = PythonOperator(
        task_id="calculate_task_eta",
        python_callable=calculate_eta
    )
