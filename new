Step 3 - Critical Path Function

get_running_tasks() ke niche add karo:

def get_critical_path_runtime(
    dag,
    task,
    runtime_map
):

    downstream = list(task.downstream_task_ids)

    if not downstream:

        return runtime_map.get(
            task.task_id,
            0
        )

    child_runtimes = []

    for child_id in downstream:

        child_task = dag.get_task(
            child_id
        )

        child_runtime = (
            get_critical_path_runtime(
                dag,
                child_task,
                runtime_map
            )
        )

        child_runtimes.append(
            child_runtime
        )

    return (
        runtime_map.get(
            task.task_id,
            0
        )
        + max(child_runtimes)
    )


