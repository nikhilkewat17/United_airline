LOOKBACK_DAYS = 7
S3_BUCKET = "dre-rms-mwaa-rms-stg"
S3_KEY_PREFIX = "dags2/reports"

def get_task_runtime(dag_id, task_id):

    runtimes = []

    lookback_date = (
        timezone.utcnow()
        - timedelta(days=LOOKBACK_DAYS)
    )

    with create_session() as session:

        task_instances = (
            session.query(TaskInstance)
            .filter(
                TaskInstance.dag_id == dag_id,
                TaskInstance.task_id == task_id,
                TaskInstance.state == State.SUCCESS,
                TaskInstance.start_date >= lookback_date
            )
            .all()
        )

        for ti in task_instances:

            if ti.duration is not None:

                runtimes.append(
                    ti.duration / 3600
                )
                
        print(
            f"TASK={task_id} | "
            f"RUN_COUNT={len(runtimes)} | "
            f"RUNTIMES={runtimes}"
        )

    if not runtimes:
        return 0

    return round(
        statistics.median(runtimes),
        2
    )

def upload_to_s3(csv_content):

    s3 = boto3.client("s3")

    file_name = (
        f"dependency_analysis_"
        f"{timezone.utcnow().strftime('%Y%m%d_%H%M%S')}.csv"
    )

    s3_key = f"{S3_KEY_PREFIX}/{file_name}"

    s3.put_object(
        Bucket=S3_BUCKET,
        Key=s3_key,
        Body=csv_content,
        ContentType="text/csv"
    )

    print(
        f"CSV uploaded to s3://{S3_BUCKET}/{s3_key}"
    )
    
def get_running_tasks(dag_id):

    with create_session() as session:

        return (
            session.query(TaskInstance)
            .filter(
                TaskInstance.dag_id == dag_id,
                TaskInstance.state == State.RUNNING
            )
            .all()
        )
        
def get_critical_path_runtime(
    dag,
    task,
    runtime_map
):

    downstream = list(task.downstream_task_ids)

    if not downstream:

        return runtime_map.get(
            task.task_id,
            0
        )

    child_runtimes = []

    for child_id in downstream:

        child_task = dag.get_task(
            child_id
        )

        child_runtime = (
            get_critical_path_runtime(
                dag,
                child_task,
                runtime_map
            )
        )

        child_runtimes.append(
            child_runtime
        )

    return (
        runtime_map.get(
            task.task_id,
            0
        )
        + max(child_runtimes)
    )


def analyze_dag(**context):

    dag_run = context.get("dag_run")

    dag_id = dag_run.conf.get("dag_id")

    if not dag_id:
        raise ValueError(
            "dag_id is mandatory"
        )

    dag = DagBag().get_dag(dag_id)

    if not dag:
        raise ValueError(
            f"DAG {dag_id} not found"
        )

    print("=" * 100)
    print(f"DAG ANALYSIS : {dag_id}")
    print("=" * 100)

    csv_buffer = io.StringIO()

    writer = csv.writer(csv_buffer)
    writer.writerow([
        "task_id",
        "median_runtime_hours",
        "upstream_tasks",
        "downstream_tasks",
        "upstream_count",
        "downstream_count"
    ])

    root_tasks = []
    end_tasks = []

    total_runtime = 0
    
    runtime_map = {}

    for task in dag.tasks:

        runtime = get_task_runtime(
            dag_id,
            task.task_id
        )
        
        runtime_map[
            task.task_id
        ] = runtime

        total_runtime += runtime

        upstream = list(
            task.upstream_task_ids
        )

        downstream = list(
            task.downstream_task_ids
        )

        if not upstream:
            root_tasks.append(
                task.task_id
            )

        if not downstream:
            end_tasks.append(
                task.task_id
            )

        print("-" * 80)

        print(
            f"TASK ID : {task.task_id}"
        )

        print(
            f"UPSTREAM : {upstream}"
        )

        print(
            f"DOWNSTREAM : {downstream}"
        )

        print(
            f"MEDIAN_RUNTIME_HOURS : {runtime}"
        )

        writer.writerow([
            task.task_id,
            runtime,
            ",".join(upstream),
            ",".join(downstream),
            len(upstream),
            len(downstream)
        ])
        
        running_tasks = get_running_tasks(
    dag_id
)

