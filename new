from datetime import datetime, timedelta
import csv
import io
import statistics
import boto3

from airflow import DAG
from airflow.operators.python import PythonOperator
from airflow.models import TaskInstance, DagBag
from airflow.utils.session import create_session
from airflow.utils.state import State
from airflow.utils import timezone


LOOKBACK_DAYS = 7

S3_BUCKET = "dre-rms-mwaa-rms-stg"
S3_KEY_PREFIX = "dags2/reports"


def get_task_runtime_hours(dag_id, task_id):

    runtimes = []

    lookback_date = (
        timezone.utcnow()
        - timedelta(days=LOOKBACK_DAYS)
    )

    with create_session() as session:

        task_instances = (
            session.query(TaskInstance)
            .filter(
                TaskInstance.dag_id == dag_id,
                TaskInstance.task_id == task_id,
                TaskInstance.state == State.SUCCESS,
                TaskInstance.start_date >= lookback_date
            )
            .all()
        )

        for ti in task_instances:

            if ti.duration is not None:

                runtimes.append(
                    ti.duration / 3600
                )

    if not runtimes:
        return 0

    return round(
        statistics.median(runtimes),
        2
    )


def upload_to_s3(csv_content):

    s3 = boto3.client("s3")

    file_name = (
        f"task_eta_"
        f"{timezone.utcnow().strftime('%Y%m%d_%H%M%S')}.csv"
    )

    s3_key = f"{S3_KEY_PREFIX}/{file_name}"

    s3.put_object(
        Bucket=S3_BUCKET,
        Key=s3_key,
        Body=csv_content,
        ContentType="text/csv"
    )

    print(
        f"CSV uploaded to s3://{S3_BUCKET}/{s3_key}"
    )


def calculate_eta(**context):

    dag_run = context.get("dag_run")

    dag_id = dag_run.conf.get("dag_id")

    if not dag_id:
        raise ValueError(
            "dag_id is mandatory"
        )

    dag = DagBag().get_dag(dag_id)

    if not dag:
        raise ValueError(
            f"DAG {dag_id} not found"
        )

    csv_buffer = io.StringIO()
    writer = csv.writer(csv_buffer)

    writer.writerow([
        "task_id",
        "median_runtime_hours"
    ])

    total_hours = 0

    business_tasks = []

    for task in dag.tasks:

        task_id = task.task_id

        if (
            "Sensor" in task_id
            or "sensor" in task_id
            or "_clean_start" in task_id
            or "_clean_end" in task_id
            or "_Success" in task_id
            or task_id.startswith("ets_")
        ):
            continue

        business_tasks.append(task_id)

    business_tasks = sorted(business_tasks)

    print("=" * 100)
    print(f"DAG : {dag_id}")
    print("=" * 100)

    for task_id in business_tasks:

        runtime = get_task_runtime_hours(
            dag_id,
            task_id
        )

        total_hours += runtime

        writer.writerow([
            task_id,
            runtime
        ])

        print(
            f"TASK={task_id} "
            f"RUNTIME={runtime} hrs"
        )

    estimated_completion_time = (
        timezone.utcnow()
        + timedelta(hours=total_hours)
    )

    writer.writerow([])
    writer.writerow(["SUMMARY"])

    writer.writerow([
        "DAG_ID",
        dag_id
    ])

    writer.writerow([
        "TOTAL_TASKS",
        len(business_tasks)
    ])

    writer.writerow([
        "TOTAL_RUNTIME_HOURS",
        round(total_hours, 2)
    ])

    writer.writerow([
        "CURRENT_TIME",
        timezone.utcnow().strftime(
            "%Y-%m-%d %H:%M:%S"
        )
    ])

    writer.writerow([
        "ESTIMATED_COMPLETION_TIME",
        estimated_completion_time.strftime(
            "%Y-%m-%d %H:%M:%S"
        )
    ])

    print("=" * 100)
    print(
        f"TOTAL_RUNTIME_HOURS = "
        f"{round(total_hours,2)}"
    )
    print(
        f"ESTIMATED_COMPLETION_TIME = "
        f"{estimated_completion_time}"
    )
    print("=" * 100)

    upload_to_s3(
        csv_buffer.getvalue()
    )


with DAG(
    dag_id="dre_cp_task_eta_calculator",
    start_date=datetime(2025, 1, 1),
    schedule=None,
    catchup=False,
    tags=["eta"]
) as dag:

    eta_task = PythonOperator(
        task_id="calculate_eta",
        python_callable=calculate_eta
    )