def upload_to_s3(csv_content):

    s3 = boto3.client("s3")

    file_name = (
        f"dependency_analysis_"
        f"{timezone.utcnow().strftime('%Y%m%d_%H%M%S')}.csv"
    )

    s3_key = f"{S3_KEY_PREFIX}/{file_name}"

    s3.put_object(
        Bucket=S3_BUCKET,
        Key=s3_key,
        Body=csv_content,
        ContentType="text/csv"
    )

    print(
        f"CSV uploaded to s3://{S3_BUCKET}/{s3_key}"
    )