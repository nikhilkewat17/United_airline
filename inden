def analyze_dag(**context):

    dag_run = context.get("dag_run")
    dag_id = dag_run.conf.get("dag_id")

    if not dag_id:
        raise ValueError("dag_id is mandatory")

    dag = DagBag().get_dag(dag_id)

    if not dag:
        raise ValueError(f"DAG {dag_id} not found")

    print("=" * 100)
    print(f"DAG ANALYSIS : {dag_id}")
    print("=" * 100)

    csv_buffer = io.StringIO()

    writer = csv.writer(csv_buffer)
    writer.writerow([
        "task_id",
        "median_runtime_hours",
        "upstream_tasks",
        "downstream_tasks",
        "upstream_count",
        "downstream_count"
    ])

    root_tasks = []
    end_tasks = []
    total_runtime = 0
    runtime_map = {}

    for task in dag.tasks:

        runtime = get_task_runtime(
            dag_id,
            task.task_id
        )

        runtime_map[task.task_id] = runtime
        total_runtime += runtime

        upstream = list(task.upstream_task_ids)
        downstream = list(task.downstream_task_ids)

        if not upstream:
            root_tasks.append(task.task_id)

        if not downstream:
            end_tasks.append(task.task_id)

        print("-" * 80)
        print(f"TASK ID : {task.task_id}")
        print(f"UPSTREAM : {upstream}")
        print(f"DOWNSTREAM : {downstream}")
        print(f"MEDIAN_RUNTIME_HOURS : {runtime}")

        writer.writerow([
            task.task_id,
            runtime,
            ",".join(upstream),
            ",".join(downstream),
            len(upstream),
            len(downstream)
        ])

    # Running tasks analysis
    running_tasks = get_running_tasks(dag_id)

    print("=" * 100)
    print("RUNNING TASKS")
    print("=" * 100)

    for rt in running_tasks:

        elapsed_hours = (
            timezone.utcnow() - rt.start_date
        ).total_seconds() / 3600

        avg_runtime = runtime_map.get(
            rt.task_id,
            0
        )

        remaining_hours = max(
            avg_runtime - elapsed_hours,
            0
        )

        estimated_end = (
            timezone.utcnow()
            + timedelta(hours=remaining_hours)
        )

        print(f"TASK={rt.task_id}")
        print(f"ELAPSED_HOURS={round(elapsed_hours, 2)}")
        print(f"AVG_RUNTIME_HOURS={avg_runtime}")
        print(f"REMAINING_HOURS={round(remaining_hours, 2)}")
        print(f"ESTIMATED_END={estimated_end}")

        print(
            f"NEXT_TASKS="
            f"{list(dag.get_task(rt.task_id).downstream_task_ids)}"
        )

    # Critical path calculation
    critical_path_hours = 0

    for root_task_id in root_tasks:

        root_task = dag.get_task(root_task_id)

        path_runtime = get_critical_path_runtime(
            dag,
            root_task,
            runtime_map
        )

        critical_path_hours = max(
            critical_path_hours,
            path_runtime
        )

    final_eta = (
        timezone.utcnow()
        + timedelta(hours=critical_path_hours)
    )

    print("=" * 100)
    print(
        f"CRITICAL_PATH_HOURS="
        f"{round(critical_path_hours, 2)}"
    )

    print(
        f"FINAL_DAG_ETA="
        f"{final_eta}"
    )

    print("=" * 100)

    print(f"ROOT TASKS : {root_tasks}")
    print(f"END TASKS : {end_tasks}")

    print(
        f"ESTIMATED_FULL_DAG_RUNTIME_HOURS : "
        f"{round(total_runtime, 2)}"
    )

    # CSV Summary
    writer.writerow([])
    writer.writerow(["SUMMARY"])

    writer.writerow([
        "TOTAL_TASKS",
        len(dag.tasks)
    ])

    writer.writerow([
        "ROOT_TASKS",
        ",".join(root_tasks)
    ])

    writer.writerow([
        "END_TASKS",
        ",".join(end_tasks)
    ])

    writer.writerow([
        "ESTIMATED_FULL_DAG_RUNTIME_HOURS",
        round(total_runtime, 2)
    ])

    writer.writerow([
        "CRITICAL_PATH_HOURS",
        round(critical_path_hours, 2)
    ])

    writer.writerow([
        "FINAL_DAG_ETA",
        final_eta.strftime("%Y-%m-%d %H:%M:%S")
    ])

    print("=" * 100)

    upload_to_s3(
        csv_buffer.getvalue()
    )


with DAG(
    dag_id="dre_dag_dependency_analysis",
    start_date=datetime(2025, 1, 1),
    schedule=None,
    catchup=False,
    tags=["analysis", "eta"]
) as dag:

    analyze_task = PythonOperator(
        task_id="analyze_dag",
        python_callable=analyze_dag
    )