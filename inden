LOOKBACK_DAYS = 7
S3_BUCKET = "dre-rms-mwaa-rms-stg"
S3_KEY_PREFIX = "dags2/reports"

def get_task_runtime(dag_id, task_id):

    runtimes = []

    lookback_date = (
        timezone.utcnow()
        - timedelta(days=LOOKBACK_DAYS)
    )

    with create_session() as session:

        task_instances = (
            session.query(TaskInstance)
            .filter(
                TaskInstance.dag_id == dag_id,
                TaskInstance.task_id == task_id,
                TaskInstance.state == State.SUCCESS,
                TaskInstance.start_date >= lookback_date
            )
            .all()
        )

        for ti in task_instances:

            if ti.duration is not None:

                runtimes.append(
                    ti.duration / 3600
                )
                
        print(
            f"TASK={task_id} | "
            f"RUN_COUNT={len(runtimes)} | "
            f"RUNTIMES={runtimes}"
        )

    if not runtimes:
        return 0

    return round(
        statistics.median(runtimes),
        2
    )

def upload_to_s3(csv_content):

    s3 = boto3.client("s3")

    file_name = (
        f"dependency_analysis_"
        f"{timezone.utcnow().strftime('%Y%m%d_%H%M%S')}.csv"
    )

    s3_key = f"{S3_KEY_PREFIX}/{file_name}"

    s3.put_object(
        Bucket=S3_BUCKET,
        Key=s3_key,
        Body=csv_content,
        ContentType="text/csv"
    )

    print(
        f"CSV uploaded to s3://{S3_BUCKET}/{s3_key}"
    )

    
    
def get_running_tasks(dag_id):

    with create_session() as session:

        return (
            session.query(TaskInstance)
            .filter(
                TaskInstance.dag_id == dag_id,
                TaskInstance.state == State.RUNNING
            )
            .all()
        )
        
def get_critical_path_runtime(
    dag,
    task,
    runtime_map
):

    downstream = list(task.downstream_task_ids)

    if not downstream:

        return runtime_map.get(
            task.task_id,
            0
        )

    child_runtimes = []

    for child_id in downstream:

        child_task = dag.get_task(
            child_id
        )

        child_runtime = (
            get_critical_path_runtime(
                dag,
                child_task,
                runtime_map
            )
        )

        child_runtimes.append(
            child_runtime
        )

    return (
        runtime_map.get(
            task.task_id,
            0
        )
        + max(child_runtimes)
    )


def analyze_dag(**context):
'''
    dag_run = context.get("dag_run")
    dag_id = dag_run.conf.get("dag_id")

    if not dag_id:
        raise ValueError("dag_id is mandatory")
'''

    dag_ids_string = (
        context["params"]
        .get("dag_ids")
    )
    dag_ids = [
        x.strip()
        for x in dag_ids_string.split(",")
        if x.strip()
    ]
    
    if not dag_ids:
        raise ValueError("Please provide DAG IDs")
    
    for dag_id in dag_ids:
        dag = DagBag().get_dag(dag_id)
        if not dag:
            print(f"DAG {dag_id} not found")
            continue
        
        root_tasks = []
        end_tasks = []
        total_runtime = 0
        runtime_map = {}
        print("=" * 120)
        print(f"DAG ANALYSIS : {dag_id}")
        print("=" * 120)
        
        print(
            f"{'DAG_ID':<25}"
            f"{'TASK_ID':<50}"
            f"{'MEDIAN_RUNTIME_HOURS':<20}"
            
        )
        

    csv_buffer = io.StringIO()

    writer = csv.writer(csv_buffer)
    writer.writerow([
        "dag_id",
        "task_id",
        "median_runtime_minutes"
    ])

    root_tasks = []
    total_runtime_minutes = 0
    runtime_map = {}

    for task in dag.tasks:

        runtime = get_task_runtime(
            dag_id,
            task.task_id
        )

        runtime_map[task.task_id] = runtime
        total_runtime_minutes += runtime

        upstream = list(task.upstream_task_ids)
        downstream = list(task.downstream_task_ids)

        if not upstream:
            root_tasks.append(task.task_id)

        print("-" * 80)

        writer.writerow([
            dag_id,
            task.task_id,
            runtime
        ])

    # Running tasks analysis
    running_tasks = get_running_tasks(dag_id)

    print("=" * 100)
    print("RUNNING TASKS")
    print("=" * 100)

    for rt in running_tasks:
        
        if not rt.start_date:
            continue

        elapsed_minutes = (
            timezone.utcnow() - rt.start_date
        ).total_seconds() / 3600

        avg_runtime_minutes = runtime_map.get(
            rt.task_id,
            0
        )

        remaining_minutes = max(
            avg_runtime_minutes - elapsed_minutes,
            0
        )

        estimated_end = (
            timezone.utcnow()
            + timedelta(minutes=remaining_minutes)
        )

        print(f"TASK={rt.task_id}")
        print(f"ELAPSED_MINUTES={round(elapsed_minutes, 2)}")
        print(f"AVG_RUNTIME_MINUTES={avg_runtime_minutes}")
        print(f"REMAINING_MINUTES={round(remaining_minutes, 2)}")
        print(f"ESTIMATED_END={estimated_end}")

        print(
            f"NEXT_TASKS="
            f"{list(dag.get_task(rt.task_id).downstream_task_ids)}"
        )
        
        
        

    # Critical path calculation
    critical_path_minutes = 0

    for root_task_id in root_tasks:

        root_task = dag.get_task(root_task_id)

        path_runtime = get_critical_path_runtime(
            dag,
            root_task,
            runtime_map
        )

        critical_path_minutes = max(
            critical_path_minutes,
            path_runtime
        )

    final_eta = (
        timezone.utcnow()
        + timedelta(minutes=critical_path_minutes)
    )

    print("=" * 100)
    print(
        f"CRITICAL_PATH_MINUTES="
        f"{round(critical_path_minutes, 2)}"
    )
    
    print(
        f"FINAL_DAG_ETA="
        f"{final_eta}"
    )

    print("=" * 100)


    print(
        f"ESTIMATED_FULL_DAG_RUNTIME_MINUTES : "
        f"{round(total_runtime_minutes, 2)}"
    )

    
    writer.writerow([])
    
    writer.writerow(["SUMMARY"])
    
    writer.writerow([
        "TOTAL_TASKS",
        len(dag.tasks)
    ])
    
    writer.writerow([
        "ESTIMATED_FULL_DAG_RUNTIME_HOURS",
        round(total_runtime_minutes, 2)
    ])
    
    writer.writerow([
        "FINAL_DAG_ETA",
        final_eta.strftime("%Y-%m-%d %H:%M:%S")
    ])
    
    print("=" * 100)

    upload_to_s3(
        csv_buffer.getvalue()
    )


